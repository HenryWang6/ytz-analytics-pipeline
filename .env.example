# AviationStack API
AVIATION_API_KEY=your_api_key_here
# AVIATION_API_URL=http://api.aviationstack.com/v1/flights
# AVIATION_API_LIMIT=100

# Snowflake — connection (shared across raw + analytics layers)
SNOWFLAKE_ACCOUNT=your_account_locator
SNOWFLAKE_USER=your_snowflake_user
SNOWFLAKE_PASSWORD=your_snowflake_password
# SNOWFLAKE_ROLE=ACCOUNTADMIN
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# Snowflake — raw layer (load stage)
# RAW_DATABASE=RAW_DB
# RAW_SCHEMA=AVIATION
# RAW_STAGE=RAW_FLIGHTS_STAGE
# RAW_TABLE=RAW_FLIGHTS
